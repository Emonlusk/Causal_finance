# ===========================================
# Causal Finance - Git Ignore
# ===========================================

# ----- ENVIRONMENT FILES -----
# NEVER commit secrets!
.env
.env.local
.env.*.local
backend/.env

# Keep examples
!.env.example
!.env.production

# ----- PYTHON -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ----- DATABASE -----
*.db
*.sqlite
*.sqlite3
instance/
backend/instance/

# ----- ML MODELS (large files) -----
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
data/models/*.pkl
data/models/*.joblib
backend/data/models/

# ----- NODE.JS -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- BUILD OUTPUT -----
dist/
build/
.output/
.nuxt/
.next/

# ----- IDE & EDITORS -----
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~

# ----- OS FILES -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----- LOGS -----
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- TESTING -----
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
coverage.xml
*.cover
.hypothesis/

# ----- MISC -----
.cache/
*.bak
*.tmp
*.temp
