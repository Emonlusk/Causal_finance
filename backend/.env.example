# Environment
FLASK_ENV=development
FLASK_DEBUG=1

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# Database
DATABASE_URL=sqlite:///causal_finance.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# FREE API KEYS - Get yours at:
# ===========================================

# FRED API (Federal Reserve Economic Data)
# Sign up at: https://fred.stlouisfed.org/docs/api/api_key.html
# Free tier: 120 requests/minute
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (Stock/ETF Data)
# Sign up at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5/minute
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Note: Yahoo Finance via yfinance library doesn't require an API key
